# Suno: use UM dos dois
# --- Recomendado: API sunoapi.org (https://docs.sunoapi.org). Obtenha a key em https://sunoapi.org/api-key
SUNOAPI_KEY=
SUNOAPI_BASE_URL=https://api.sunoapi.org

# --- Alternativa: lib SunoAI com cookie (app.suno.ai -> DevTools -> Network -> Cookie)
SUNO_COOKIE=your_suno_cookie_here

# API Key para proteger o endpoint POST /generate
API_KEY=your_secret_api_key_here

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_GENERATE=music-generation-requests
KAFKA_TOPIC_PUBLISH=video-ready-for-youtube

# Diretórios de trabalho (opcional)
WORK_DIR=./work
DOWNLOADS_DIR=./downloads
OUTPUT_VIDEOS_DIR=./output_videos

# YouTube (para o consumer de publicação)
# Caminho para client_secrets.json do Google Cloud Console
GOOGLE_CLIENT_SECRETS_PATH=./client_secrets.json
# Opcional: qual conta/canal usar (path do credentials.json). Vazio = credentials.json ao lado do client_secrets
YOUTUBE_CREDENTIALS_PATH=

# Categoria do vídeo no YouTube (22 = People & Blogs, 10 = Music)
YOUTUBE_CATEGORY_ID=10
YOUTUBE_PRIVACY_STATUS=private
